#!/bin/bash

# gt - Ghostty opacity management CLI
# A simple CLI tool for managing Ghostty background opacity

CONFIG_FILE="$HOME/.config/ghostty/config"
SCRIPT_NAME="$(basename "$0")"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

print_usage() {
  echo "Usage: $SCRIPT_NAME [COMMAND|VALUE]"
  echo ""
  echo "Commands:"
  echo "  toggle, t           Toggle between transparent (0.95) and opaque (1.0)"
  echo "  show, s             Show current opacity value"
  echo "  help, h, --help     Show this help message"
  echo ""
  echo "Set opacity:"
  echo "  VALUE               Set opacity to specific value (0.0-1.0)"
  echo ""
  echo "Examples:"
  echo "  $SCRIPT_NAME              # Toggle opacity"
  echo "  $SCRIPT_NAME t            # Toggle opacity"
  echo "  $SCRIPT_NAME 0.8          # Set to 80% opacity"
  echo "  $SCRIPT_NAME 0.5          # Set to 50% opacity"
  echo "  $SCRIPT_NAME 1            # Set to 100% opacity (opaque)"
  echo "  $SCRIPT_NAME show         # Show current opacity"
  echo ""
  echo "Presets:"
  echo "  transparent, trans    Set to 0.8 (80%)"
  echo "  semi, medium         Set to 0.9 (90%)"
  echo "  opaque, solid        Set to 1.0 (100%)"
}

print_error() {
  echo -e "${RED}Error:${NC} $1" >&2
}

print_success() {
  echo -e "${GREEN}✓${NC} $1"
}

print_info() {
  echo -e "${BLUE}ℹ${NC} $1"
}

get_current_opacity() {
  local opacity
  opacity=$(grep "^background-opacity" "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2 | xargs)

  if [ -z "$opacity" ]; then
    echo "1.0"
  else
    echo "$opacity"
  fi
}

validate_opacity() {
  local value="$1"

  # Check if it's a valid number between 0 and 1
  if ! [[ "$value" =~ ^0*(\.[0-9]+)?$|^1(\.0*)?$ ]] || [ "$(echo "$value > 1" | bc -l 2>/dev/null)" = "1" ]; then
    return 1
  fi
  return 0
}

set_opacity() {
  local new_opacity="$1"
  local temp_file
  temp_file=$(mktemp)

  if grep -q "^background-opacity" "$CONFIG_FILE" 2>/dev/null; then
    # Replace existing line
    sed "s/^background-opacity.*$/background-opacity = $new_opacity/" "$CONFIG_FILE" >"$temp_file"
  else
    # Add new line to existing config or create if doesn't exist
    if [ -f "$CONFIG_FILE" ]; then
      cp "$CONFIG_FILE" "$temp_file"
    else
      mkdir -p "$(dirname "$CONFIG_FILE")"
      touch "$temp_file"
    fi
    echo "background-opacity = $new_opacity" >>"$temp_file"
  fi

  # Move temp file back to config
  mv "$temp_file" "$CONFIG_FILE"

  # Try to reload (platform-specific)
  if command -v osascript &>/dev/null; then
    print_info "On macOS, you may need to restart Ghostty for changes to take effect cmd+shift+,"
  else
    pkill -SIGUSR1 ghostty 2>/dev/null || true
  fi
}

# Check if config file directory exists
if [ ! -f "$CONFIG_FILE" ] && [ ! -d "$(dirname "$CONFIG_FILE")" ]; then
  print_error "Ghostty config directory not found. Creating $(dirname "$CONFIG_FILE")"
  mkdir -p "$(dirname "$CONFIG_FILE")"
fi

# Parse arguments
case "${1:-toggle}" in
"help" | "h" | "--help" | "-h")
  print_usage
  exit 0
  ;;
"show" | "s")
  current=$(get_current_opacity)
  percentage=$(echo "$current * 100" | bc -l | cut -d. -f1)
  print_info "Current opacity: $current (${percentage}%)"
  exit 0
  ;;
"toggle" | "t" | "")
  current=$(get_current_opacity)
  if [ "$current" = "1" ] || [ "$current" = "1.0" ]; then
    new_opacity="0.95"
    print_success "Toggled: opaque → transparent (${new_opacity})"
  else
    new_opacity="1.0"
    print_success "Toggled: transparent → opaque (${new_opacity})"
  fi
  set_opacity "$new_opacity"
  ;;
"transparent" | "trans")
  new_opacity="0.8"
  print_success "Set to transparent preset (${new_opacity})"
  set_opacity "$new_opacity"
  ;;
"semi" | "medium")
  new_opacity="0.9"
  print_success "Set to semi-transparent preset (${new_opacity})"
  set_opacity "$new_opacity"
  ;;
"opaque" | "solid")
  new_opacity="1.0"
  print_success "Set to opaque preset (${new_opacity})"
  set_opacity "$new_opacity"
  ;;
*)
  # Try to parse as numeric value
  if validate_opacity "$1"; then
    current=$(get_current_opacity)
    percentage=$(echo "$1 * 100" | bc -l | cut -d. -f1)
    print_success "Opacity: $current → $1 (${percentage}%)"
    set_opacity "$1"
  else
    print_error "Invalid opacity value: '$1'"
    echo "Opacity must be between 0.0 and 1.0"
    echo ""
    print_usage
    exit 1
  fi
  ;;
esac
